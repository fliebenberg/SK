# WebSocket Connection URL for the backend Socket.io server.
#
# In local development:
# - Leave this variable commented out or empty. The app will dynamically resolve:
#   - http://10.0.2.2:3001  (Android Emulator to connect to your computer)
#   - http://localhost:3001 (iOS Simulator / Web Browser)
# - Physical Android Device: If testing on a real phone, uncomment this and replace with your computer's local IP address.
#   Example: EXPO_PUBLIC_WS_URL=http://192.168.1.50:3001
#
# In production:
# - Set this to your deployed backend secure WebSocket endpoint (HTTPS).
#   Example: EXPO_PUBLIC_WS_URL=https://api.yourdomain.com
#
# EXPO_PUBLIC_WS_URL=http://localhost:3001

# Google Maps API Key for Android SDK
EXPO_PUBLIC_ANDROID_GOOGLE_MAPS_API_KEY=your_android_google_maps_api_key_here

# Google Maps API Key for Web (HTTP Referrers restricted)
EXPO_PUBLIC_WEB_GOOGLE_MAPS_API_KEY=your_web_google_maps_api_key_here
